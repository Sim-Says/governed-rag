# ── Environment Variables for Governed RAG ──
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Ollama Settings (Using Ollama Cloud or Local)
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_BASE_URL=https://api.ollama.ai/v1  # or http://localhost:11434/v1

# Models
GENERATION_MODEL=gemma3:4b
JUDGE_MODEL=ministral-3:8b
EMBEDDING_MODEL_PATH=data/models/all-MiniLM-L6-v2
